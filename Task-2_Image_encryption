from PIL import Image
import numpy as np


def encrypt_image(input_path, output_path, key_path):
    img = Image.open(input_path)
    img_array = np.array(img)

    key = np.random.randint(0, 256, img_array.shape, dtype=np.uint8)
    encrypted = np.bitwise_xor(img_array, key)

    Image.fromarray(encrypted).save(output_path)
    np.save(key_path, key)

    print("Image encrypted and key saved")


def decrypt_image(encrypted_path, output_path, key_path):

    encrypted_img = Image.open(encrypted_path)
    encrypted_array = np.array(encrypted_img)

    key = np.load(key_path)

    decrypted = np.bitwise_xor(encrypted_array, key)

    Image.fromarray(decrypted).save(output_path)

    print("Image decrypted successfully")


def main():
    print("=" * 50)
    print("               IMAGE ENCRYPTION TOOL")
    print("=" * 50)

    while True:
        print("1. Encrypt Image")
        print("2. Decrypt Image")
        print("3. Exit")

        choice = input("Choose: ")

        if choice == '1':
            inp = input("Input image's Name with extension: ")
            out = input("Encrypted image's Name with extension: ")
            key = input("Key file name(e.g :key.npy): ")

            encrypt_image(inp, out, key)

        elif choice == '2':
            enc = input("Encrypted image's Name with extension: ")
            out = input("Decrypted image's Name with extension: ")
            key = input("Key file name(e.g :key.npy): ")

            decrypt_image(enc, out, key)

        elif choice == '3':
            print("Exiting...")
            break

        else:
            print("Invalid choice")


if __name__ == "__main__":
    main()